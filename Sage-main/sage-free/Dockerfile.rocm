FROM rocm/pytorch:rocm6.2_ubuntu22.04_py3.10_pytorch_2.4.0

ENV PYTORCH_ROCM_ARCH="gfx942"
ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    python3-pip \
    libgl1-mesa-glx \
    && rm -rf /var/lib/apt/lists/*

# Install vLLM for ROCm
RUN pip install --no-cache-dir vllm==0.6.0 --index-url https://download.pytorch.org/whl/rocm6.2

# Copy requirements and install
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the rest of the application
COPY . .

# Expose FastAPI and Gradio
EXPOSE 8000
EXPOSE 7860

# Default command
CMD ["python3", "-m", "sage.api.server"]
